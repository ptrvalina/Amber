# --- Amber ---
AMBER_ENV=dev
AMBER_LOG_LEVEL=INFO
AMBER_CORS_ORIGINS=*
AMBER_ENABLE_CONSOLE=true
AMBER_ENABLE_DOCS=true
AMBER_STRICT_ROUTING=true
AMBER_STRICT_FIAT_GUARD=true
# Опционально: если задан — нужен заголовок X-Api-Key или Authorization: Bearer …
# AMBER_API_KEY=

AMBER_LLM_TIMEOUT_SECONDS=120
AMBER_MAX_PROFILER_TRANSACTIONS=5000
AMBER_MAX_LLM_HISTORICAL=150
AMBER_MAX_LLM_PAYLOAD_CHARS=120000

AMBER_LLM_PRIMARY=openai
AMBER_OPENAI_MODEL=gpt-4o
AMBER_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Провайдеры LLM (хотя бы один) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Рекомендуется Python 3.12. На 3.14 под Windows часть колёс (PyYAML и др.) может отсутствовать.
